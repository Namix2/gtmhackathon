# =============================================================================
# Champion Discovery — environment variables
# =============================================================================
# Local dev:  put NON-secret config in .env, and SECRETS in .env.local
#             (.env.local is gitignored; .env is NOT — never put secrets in .env)
# Production: set these in your host's environment-variable settings
#             (Vercel/Render/Fly/Railway/Docker), not in a committed file.
#
# Copy this file to .env.local and fill in the values you need.
# A source only runs if it is (1) enabled, (2) configured, (3) linked to a net,
# and (4) has the credentials below.
# =============================================================================

# --- Database (required) -----------------------------------------------------
# SQLite is fine for a single long-running instance with a persistent disk.
# For serverless/multi-instance prod, switch the Prisma datasource to Postgres
# and use a pooled connection string here.
DATABASE_URL="file:./dev.db"

# --- Reddit agent (keyless by default; all vars below are OPTIONAL) ----------
# The Reddit source works with NO credentials: it reads Reddit's public .json
# endpoints (no app, no OAuth, no redirect URI). Just set a descriptive
# User-Agent below and you're done.
#
# Optional upgrade: if you set REDDIT_CLIENT_ID + REDDIT_CLIENT_SECRET (create a
# "script" app at https://www.reddit.com/prefs/apps), the agent uses the OAuth
# host for HIGHER rate limits. Adding REDDIT_USERNAME + REDDIT_PASSWORD switches
# it to the password grant; otherwise it uses client_credentials.
#
# Reddit requires a descriptive, unique User-Agent (recommended even keyless).
REDDIT_USER_AGENT="champion-discovery/0.1 (by /u/your_reddit_username)"
# Optional (higher rate limits only):
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USERNAME=""
REDDIT_PASSWORD=""

# --- X (Twitter) agent (required to run the X source) ------------------------
# App-only OAuth 2.0 Bearer token. NOTE: tweet search requires the Basic tier
# or higher — the Free tier returns 403 for search endpoints.
X_BEARER_TOKEN=""

# --- LinkedIn -----------------------------------------------------------------
# No API key. LinkedIn has no compliant public content API; use the JSON
# import on the LinkedIn source setup page (licensed provider or manual export).

# --- Optional: LLM enrichment ------------------------------------------------
# Enables the "AI enrich" button (signal classification + outreach-angle draft).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- RSS Engine (canonical ingestion) ------------------------------------------
# Discovery providers. When EXA_API_KEY and TAVILY_API_KEY are both unset,
# the engine uses deterministic mock clients (set RSS_ENGINE_MOCK_PROVIDERS=true
# to force mocks even when keys are present).
EXA_API_KEY=""
TAVILY_API_KEY=""
RSSHUB_BASE_URL="https://rsshub.app"
RSSBRIDGE_BASE_URL="https://rss-bridge.org/bridge01"
RSS_APP_API_KEY=""
DEFAULT_POLL_INTERVAL_MINUTES="60"
USER_AGENT="LightfernRSSBot/0.1"
RSS_ENGINE_MOCK_PROVIDERS="true"
RSS_FETCH_TIMEOUT_MS="10000"
RSS_FETCH_RETRIES="1"
RSS_DISCOVERY_CONCURRENCY="8"
RSS_POLL_CONCURRENCY="6"
RSS_DISCOVERY_MAX_RESULTS="12"
RSS_POLL_LIMIT="20"
# Optional: Redis is reserved for future job queues / caching (not required today)
REDIS_URL=""
